{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/pages/api/ai/chat.ts": {
      "maxDuration": 60
    },
    "src/pages/api/ai/report.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "origin-when-cross-origin" }
      ]
    }
  ]
}
